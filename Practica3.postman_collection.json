          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Movie A\",\n  \"director\": \"Director A\",\n  \"genre\": \"sci-fi\",\n  \"year\": 2023,\n  \"rating\": 8.5\n}"
            },
            "url": {
              "raw": "{{base_url}}/movies",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "movies"
