                  "pm.test(\"Ambas peliculas (A y B) estan presentes\", function () {",
                  "    const body = pm.response.json();",
                  "    const idA = pm.collectionVariables.get(\"idA\");",
                  "    const idB = pm.collectionVariables.get(\"idB\");",
                  "    ",
                  "    const hasA = body.some(m => m.id === idA);",
                  "    const hasB = body.some(m => m.id === idB);",
                  "    ",
                  "    pm.expect(hasA).to.be.true;",
                  "    pm.expect(hasB).to.be.true;",
                  "});"
