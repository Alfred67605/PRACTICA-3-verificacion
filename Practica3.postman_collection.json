      "name": "01 Filtrado Query Params",
      "item": [
        {
          "name": "P1-01 GET /movies?genre=sci-fi",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"All movies match the genre filter\", function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.be.an(\"array\");",
                  "    if (body.length > 0) {",
                  "        pm.expect(body.every(m => m.genre === \"sci-fi\")).to.be.true;",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/movies?genre=sci-fi",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "movies"
              ],
              "query": [
                {
                  "key": "genre",
                  "value": "sci-fi"
                }
              ]
            }
          }
        },
