        {
          "name": "P1-05 GET /movies?genre=musical",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 'musical' is not a valid enum value so ValidationPipe throws 422",
                  "pm.test(\"Status code is 422 o 200 ([] array vacio)\", function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 422]);",
                  "});",
                  "pm.test(\"Explicacion del comportamiento real\", function () {",
                  "    if (pm.response.code === 422) {",
                  "        console.log('Se devolvio 422 porque \"musical\" no está en el Enum Genre de ValidationPipe');",
                  "    } else {",
                  "        console.log('Se devolvio 200 [] vacío porque no se aplicó validador de Enum estricto');",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/movies?genre=musical",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "movies"
              ],
              "query": [
                {
                  "key": "genre",
                  "value": "musical"
                }
              ]
            }
          }
        },
