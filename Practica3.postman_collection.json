          "name": "P2-01 POST /movies",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "const body = pm.response.json();",
                  "if(body && body.id) {",
                  "    pm.collectionVariables.set(\"idA\", body.id);",
                  "}"
                ]
              }
            }
